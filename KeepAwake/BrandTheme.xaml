<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- bdh-utils brand palette. Single source of truth for all colours. -->
    <Color x:Key="BrandBgColor">#191919</Color>
    <Color x:Key="BrandSurfaceColor">#313531</Color>
    <Color x:Key="BrandMutedColor">#5A5E5A</Color>
    <Color x:Key="BrandTextColor">#FFFFFF</Color>
    <Color x:Key="BrandAccentColor">#F15025</Color>

    <SolidColorBrush x:Key="BrandBg" Color="{StaticResource BrandBgColor}"/>
    <SolidColorBrush x:Key="BrandSurface" Color="{StaticResource BrandSurfaceColor}"/>
    <SolidColorBrush x:Key="BrandMuted" Color="{StaticResource BrandMutedColor}"/>
    <SolidColorBrush x:Key="BrandText" Color="{StaticResource BrandTextColor}"/>
    <SolidColorBrush x:Key="BrandAccent" Color="{StaticResource BrandAccentColor}"/>
</ResourceDictionary>
